#!/bin/bash
# config_callback —— 依据安装/设置向导输入，生成 Traefik 配置到共享数据目录。
#
# 运行时模型（见 fn-fpk 规范 §9.1）：
#   ${TRIM_APPDEST}         = 包内代码目录（target，只读），含 docker/traefik.yaml 与 docker/dynamic/ 种子
#   ${TRIM_DATA_SHARE_PATHS}= 可写共享目录（冒号分隔，取首个），容器内挂载为 /data
# 生成/拷贝的内容统一落在 $DATA 下，由 Traefik file provider 热加载，无需重启容器。
# 本脚本同时被 install_callback（安装后）与 config_callback（设置变更后）调用。

set -euo pipefail

# ── 定位包内 docker 目录（优先 TRIM_APPDEST，兼容回退 TRIM_PKGVAR）──
PKG_DOCKER=""
for cand in "${TRIM_APPDEST}/docker" "${TRIM_PKGVAR}/docker" "${TRIM_APPDEST}" "${TRIM_PKGVAR}"; do
  if [ -d "$cand" ] && { [ -f "$cand/traefik.yaml" ] || [ -f "$cand/dynamic/external-service.yml" ]; }; then
    PKG_DOCKER="$cand"
    break
  fi
done
if [ -z "$PKG_DOCKER" ]; then
  echo "找不到包内 docker 目录（TRIM_APPDEST=$TRIM_APPDEST, TRIM_PKGVAR=$TRIM_PKGVAR）" > "${TRIM_TEMP_LOGFILE:-/dev/null}"
  exit 1
fi

# ── 共享数据目录（取首个路径，避免冒号列表在挂载时产生多冒号）──
DATA="${TRIM_DATA_SHARE_PATHS%%:*}"
mkdir -p "${DATA}/dynamic" "${DATA}/certificates" "${DATA}/data"

# ── 读取向导变量（带默认值）──
DOMAIN="${wizard_domain:-}"
TZ="${wizard_tz:-Asia/Shanghai}"
TLS_MODE="${wizard_tls_mode:-selfsigned}"
CERT_FILE="${wizard_cert_file:-fullchain.pem}"
KEY_FILE="${wizard_key_file:-privkey.pem}"
ACME_EMAIL="${wizard_acme_email:-}"
ACME_CA="${wizard_acme_ca:-prod}"
HTTPS_ONLY="${wizard_https_only:-true}"
DASH_ENABLE="${wizard_dashboard_enable:-false}"
DASH_USER="${wizard_dashboard_user:-admin}"
DASH_PASS="${wizard_dashboard_pass:-}"

# 把包内静态配置拷到共享目录，并填入 ACME CA 地址（prod/staging）
if [ -f "$PKG_DOCKER/traefik.yaml" ]; then
  cp -f "$PKG_DOCKER/traefik.yaml" "${DATA}/traefik.yaml"
  CASERVER="https://acme-v02.api.letsencrypt.org/directory"
  if [ "${ACME_CA}" = "staging" ]; then
    CASERVER="https://acme-staging-v02.api.letsencrypt.org/directory"
  fi
  # 兼容 GNU/BSD sed 的就地替换
  sed -i "s#__ACME_CASERVER__#${CASERVER}#g" "${DATA}/traefik.yaml"
fi

# 提取注册域（最后两段）用于 ACME 泛域名 SAN：nas.example.com -> example.com
regdomain() {
  local d="$1"
  local oifs="$IFS"; IFS='.'; set -- $d; IFS="$oifs"
  if [ "$#" -ge 2 ]; then
    local n=$#; local penult; local last
    eval "penult=\$$((n-1))"; eval "last=\$$n"
    echo "${penult}.${last}"
  else
    echo "$d"
  fi
}
WILDCARD="*.$(regdomain "${DOMAIN}")"

# 路由层面的 TLS 声明（基准缩进 6 空格，与 entryPoints/service 同级）：
if [ "${TLS_MODE}" = "acme" ] && [ -n "${DOMAIN}" ]; then
  ROUTE_TLS="$(cat <<EOF
      tls:
        certResolver: letsencrypt
        domains:
          - main: "${DOMAIN}"
            sans:
              - "${WILDCARD}"
EOF
)"
else
  ROUTE_TLS="      tls: {}"
fi

OUT="${DATA}/dynamic"

# ── 1) 中间件（secure-headers 必选；basic-auth 占位；custom 模式加载自有证书 TLS Store）──
{
  echo "# 动态中间件与 TLS 配置（由向导自动生成，改设置后重生成）"
  echo "# 被静态配置与路由引用：secure-headers@file / basic-auth@file。"
  echo "http:"
  echo "  middlewares:"
  echo "    # 安全响应头：允许被飞牛桌面以 iframe 内嵌"
  echo "    secure-headers:"
  echo "      headers:"
  echo "        sslRedirect: false"
  echo "        frameDeny: false"
  echo "        customFrameOptionsValue: \"\""
  echo "        contentTypeNosniff: true"
  echo "        browserXssFilter: true"
  echo "        customResponseHeaders:"
  echo "          Content-Security-Policy: \"frame-ancestors *;\""
  echo "        sslProxyHeaders:"
  echo "          X-Forwarded-Proto: \"https\""
  echo ""
  echo "    # 通用 BasicAuth（用于 external-service.yml 中需要密码保护的服务）"
  echo "    basic-auth:"
  echo "      basicAuth:"
  echo "        users:"
  echo "          - \"admin:\$2y\$05\$REPLACE_WITH_YOUR_htpasswd_OUTPUT\""
} > "${OUT}/middlewares.yml"

# 自有证书模式：在数据目录 certificates/ 下放置 cert/key，加载为默认证书
if [ "${TLS_MODE}" = "custom" ]; then
  {
    echo ""
    echo "# 自有证书（custom 模式）：作为默认证书对所有 HTTPS 域名生效"
    echo "tls:"
    echo "  stores:"
    echo "    default:"
    echo "      defaultCertificate:"
    echo "        certFile: \"/data/certificates/${CERT_FILE}\""
    echo "        keyFile: \"/data/certificates/${KEY_FILE}\""
  } >> "${OUT}/middlewares.yml"
fi

# ── 2) 飞牛系统主页反代（始终生成）──
{
  echo "# 飞牛(FnOS) 系统主页反代 —— 由向导自动生成"
  echo "# 访问 https://你的域名 即反代到飞牛主页。其它子域名服务请在 external-service.yml 添加。"
  echo "http:"
  echo "  routers:"
  echo "    fnos-system-https:"
  echo "      entryPoints: [websecure]"
  if [ -n "${DOMAIN}" ]; then
    echo "      rule: \"Host(\`${DOMAIN}\`)\""
  else
    echo "      # 未配置域名时作为兜底网关（请尽快在设置中填写基础域名）"
  fi
  echo "      service: fnos-system-https"
  echo "      middlewares:"
  echo "        - secure-headers@file"
  echo "${ROUTE_TLS}"
  echo "      priority: 1"
  echo ""
  echo "  services:"
  echo "    fnos-system-https:"
  echo "      loadBalancer:"
  echo "        serversTransport: fnos-skip-tls   # 飞牛 HTTPS 为自签证书，跳过校验"
  echo "        servers:"
  echo "          - url: \"https://host.docker.internal:5667\""
  echo "        passHostHeader: true"
  echo ""
  echo "  serversTransports:"
  echo "    fnos-skip-tls:"
  echo "      insecureSkipVerify: true"
} > "${OUT}/fnos.yml"

# ── 3) HTTPS Only 跳转（仅开启时生成）──
if [ "${HTTPS_ONLY}" = "true" ]; then
  {
    echo "# HTTP -> HTTPS 全量跳转（开启 HTTPS Only 时生成）"
    echo "http:"
    echo "  routers:"
    echo "    http-to-https:"
    echo "      entryPoints: [web]"
    echo "      rule: \"HostRegexp(\`.*\`)\""
    echo "      middlewares: [redirect-to-https@file]"
    echo "      service: dummy-svc"
    echo "      priority: 2"
    echo "  services:"
    echo "    dummy-svc:"
    echo "      loadBalancer:"
    echo "        servers:"
    echo "          - url: \"http://127.0.0.1:65535\""
    echo "  middlewares:"
    echo "    redirect-to-https:"
    echo "      redirectScheme:"
    echo "        scheme: https"
    echo "        port: \"443\""
    echo "        permanent: true"
  } > "${OUT}/redirect.yml"
else
  rm -f "${OUT}/redirect.yml"
fi

# ── 4) 远程 Dashboard（仅启用且提供密码时生成）──
if [ "${DASH_ENABLE}" = "true" ] && [ -n "${DASH_PASS}" ]; then
  HASH="$(openssl passwd -apr1 "${DASH_PASS}" 2>/dev/null || true)"
  if [ -n "${HASH}" ]; then
    {
      echo "# Dashboard 远程访问 BasicAuth（由向导自动生成，请勿手改）"
      echo "http:"
      echo "  middlewares:"
      echo "    dash-auth:"
      echo "      basicAuth:"
      echo "        users:"
      echo "          - \"${DASH_USER}:${HASH}\""
    } > "${OUT}/auth.yml"
    {
      echo "# 远程访问 Dashboard（经 HTTPS 入口 + BasicAuth 保护）"
      echo "http:"
      echo "  routers:"
      echo "    dashboard:"
      echo "      entryPoints: [websecure]"
      if [ -n "${DOMAIN}" ]; then
        echo "      rule: \"Host(\`${DOMAIN}\`) && PathPrefix(\`/dashboard\`)\""
      fi
      echo "      service: api@internal"
      echo "      middlewares:"
      echo "        - secure-headers@file"
      echo "        - dash-auth@file"
      echo "${ROUTE_TLS}"
      echo "      priority: 100"
    } > "${OUT}/dashboard.yml"
  else
    echo "openssl 不可用，无法生成 Dashboard 密码哈希，已跳过远程 Dashboard 路由。" > "${TRIM_TEMP_LOGFILE:-/dev/null}"
    rm -f "${OUT}/dashboard.yml" "${OUT}/auth.yml"
  fi
else
  rm -f "${OUT}/dashboard.yml" "${OUT}/auth.yml"
fi

# ── 5) 反代「其它服务」示例模板（首次安装时拷贝到数据目录，之后保留用户修改）──
seed() {
  local name
  name="$(basename "$1")"
  if [ ! -f "${OUT}/${name}" ] && [ -f "$1" ]; then
    cp "$1" "${OUT}/${name}"
  fi
}
seed "${PKG_DOCKER}/dynamic/external-service.yml"

# ── 6) ACME 证书存储文件权限（Traefik 要求 600）──
if [ "${TLS_MODE}" = "acme" ]; then
  touch "${DATA}/acme.json" 2>/dev/null || true
  chmod 600 "${DATA}/acme.json" 2>/dev/null || true
fi

exit 0
