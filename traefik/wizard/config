[
  {
    "stepTitle": "基础设置",
    "items": [
      {
        "type": "text",
        "field": "wizard_fnos_http_port",
        "label": "飞牛系统 HTTP 端口",
        "initValue": "5666",
        "helpText": "飞牛设置 → 网络/常规 中的 HTTP 端口。V0.8.22 起默认 5666（更早版本为 8000）。",
        "rules": [
          { "required": true, "message": "请输入飞牛 HTTP 端口" },
          { "pattern": "^[0-9]+$", "message": "端口必须为数字" }
        ]
      },
      {
        "type": "text",
        "field": "wizard_fnos_https_port",
        "label": "飞牛系统 HTTPS 端口",
        "initValue": "5667",
        "helpText": "飞牛设置 → 网络/常规 中的 HTTPS 端口。V0.8.22 起默认 5667（更早版本为 8001）。",
        "rules": [
          { "required": true, "message": "请输入飞牛 HTTPS 端口" },
          { "pattern": "^[0-9]+$", "message": "端口必须为数字" }
        ]
      },
      {
        "type": "text",
        "field": "wizard_domain",
        "label": "反代域名（可选）",
        "initValue": "",
        "helpText": "留空则 Traefik 作为兜底网关直接反代飞牛主页（50080/50443 均可访问）；填写后按 Host 匹配（如 nas.example.com）。"
      },
      {
        "type": "text",
        "field": "wizard_tz",
        "label": "时区",
        "initValue": "Asia/Shanghai",
        "helpText": "容器时区，影响日志时间显示。"
      }
    ]
  },
  {
    "stepTitle": "安全选项",
    "items": [
      {
        "type": "switch",
        "field": "wizard_https_only",
        "label": "启用 HTTPS Only（HTTP 50080 强制跳转 HTTPS 50443）",
        "initValue": "false",
        "helpText": "开启后所有 HTTP 明文访问将被 301 跳转到 HTTPS；关闭则同时保留两个入口（默认，局域网明文可达）。"
      },
      {
        "type": "switch",
        "field": "wizard_dashboard_enable",
        "label": "启用远程访问 Dashboard（50443 + 账号密码）",
        "initValue": "false",
        "helpText": "开启后需设置下方账号密码，远程经 50443 访问 Traefik Dashboard 时要求 BasicAuth 校验。"
      },
      {
        "type": "text",
        "field": "wizard_dashboard_user",
        "label": "Dashboard 账号",
        "initValue": "admin",
        "rules": [
          { "required": true, "message": "请输入 Dashboard 账号" }
        ]
      },
      {
        "type": "password",
        "field": "wizard_dashboard_pass",
        "label": "Dashboard 密码",
        "rules": [
          { "min": 6, "message": "密码至少 6 位" }
        ]
      }
    ]
  }
]
