#!/bin/bash
# MoviePilot 生命周期：Docker 应用，启停由 compose 管理，此处仅做状态检查
FILE_PATH="${TRIM_APPDEST}/docker/docker-compose.yaml"

is_docker_running() {
  DOCKER_NAME=""
  if [ -f "$FILE_PATH" ]; then
    DOCKER_NAME=$(grep "container_name" "$FILE_PATH" | awk -F ':' '{print $2}' | xargs)
  fi
  if [ -n "$DOCKER_NAME" ]; then
    if docker inspect "$DOCKER_NAME" 2>/dev/null | grep -q "\"Status\": \"running\","; then
      return 0
    fi
    return 1
  fi
  return 1
}

case $1 in
  start)  exit 0 ;;
  stop)   exit 0 ;;
  status) if is_docker_running; then exit 0; else exit 3; fi ;;
  *)      exit 1 ;;
esac
